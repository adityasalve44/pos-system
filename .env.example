# Database — PlanetScale or any MySQL 8 instance
DATABASE_URL=mysql://user:password@host/pos_db?ssl={"rejectUnauthorized":true}

# NextAuth v5 — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-secret-here
AUTH_SECRET=your-secret-here

# Seed API Authorization — generate with: openssl rand -base64 32
SEED_SECRET=your-seed-secret-here

# App URL
NEXTAUTH_URL=http://localhost:3000
